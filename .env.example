# ─────────────────────────────────────────────────────────────
# Spinframe Portal — Environment Variables
# Copy this file to `.env` for local development (used by `vercel dev`),
# and set the same variables in the Vercel dashboard for production.
# ─────────────────────────────────────────────────────────────

# --- Role passwords (server-side only; never exposed to the browser) ---
SPINFRAME_PASSWORD=change-me-spinframe
QUBE_PASSWORD=change-me-qube

# --- Google Sheets ---
# The ID is the long string in the sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=
# Name of the tab/worksheet that holds the solution data (defaults to "Sheet1")
GOOGLE_SHEET_NAME=Status

# --- Google Service Account credentials ---
# From the downloaded service-account JSON key file.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the full private key. Keep the surrounding quotes and the literal \n
# escape sequences exactly as they appear in the JSON file.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
